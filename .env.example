# ─── Brokerra Backend — Environment Variables ─────────────────────────────────
# Copy to .env and fill in your values

# Database
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/brokerra"

# JWT
JWT_SECRET="brokerra-super-secret-key-2024-never-share-this-xyz-abc-987"
JWT_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV=development

# CORS — frontend origin
FRONTEND_URL=http://localhost:3000

# Optional: AI summary verbosity (1-3)
AI_SUMMARY_DETAIL=2
